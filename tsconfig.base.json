{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@naruto5e/shared": ["packages/shared/src/index.ts"],
      "@naruto5e/shared/*": ["packages/shared/src/*"],
      "@naruto5e/engine": ["packages/engine/src/index.ts"],
      "@naruto5e/engine/*": ["packages/engine/src/*"],
      "@naruto5e/mcp-controller": ["packages/mcp-controller/src/index.ts"],
      "@naruto5e/mcp-controller/*": ["packages/mcp-controller/src/*"]
    }
  }
}
