# ─────────────────────────────────────────────────────────────────────────────
# Naruto 5e — environment configuration.
# Copy this file to `.env` and fill in your key. `.env` is gitignored; this
# `.env.example` is the committed template. Real shell exports override the file.
# ─────────────────────────────────────────────────────────────────────────────

# Autonomous NPC agents (the durable agent layer) are driven through this key:
# an NPC's persona + directive + secrets + the current situation are composed into
# a prompt and sent to the model, which answers IN CHARACTER with a declared intent
# ("I slip into the crowd and palm the scroll."), which the DM then resolves.
OPENAI_API_KEY=

# Model that drives NPC agents. No temperature knob is exposed — gpt-5.x reasoning
# models manage their own sampling, and the agent config intentionally omits it.
NARUTO_NPC_MODEL=gpt-5.4-mini

# Optional — Anthropic-backed headless DM brain (packages/harness). Leave the key
# blank to run the DM in deterministic-parser fallback (no LLM, no key required).
ANTHROPIC_API_KEY=
NARUTO_DM_MODEL=claude-opus-4-8

# Where the deterministic engine listens (controller + harness read this).
NARUTO_ENGINE_URL=http://localhost:8970
