{
  "name": "naruto5e",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Naruto 5e — a three-tier deterministic RPG engine (engine / MCP controller / DM harness).",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch packages/engine/src/server.ts",
    "start": "tsx packages/engine/src/server.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "mcp": "tsx packages/mcp-controller/src/index.ts",
    "dm": "tsx packages/harness/src/cli.ts",
    "smoke": "tsx packages/engine/src/scripts/smoke.ts"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^2.1.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "express": "^4.21.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.3.0"
  }
}
